.proj-tag.gray{background:var(--bg);color:var(--text3);border:1px solid var(--border)}
.proj-links{display:flex;gap:10px;margin-top:4px}
.proj-link{font-size:12px;font-weight:600;color:var(--blue);text-decoration:none;display:inline-flex;align-items:center;gap:4px}
