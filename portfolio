.exp-company{font-size:13px;font-weight:700;color:var(--text)}
.exp-loc{font-size:12px;color:var(--text3);margin-top:2px}
.exp-badge{display:inline-block;font-size:10px;font-weight:700;background:var(--blue);color:var(--white);padding:3px 8px;border-radius:4px;margin-top:8px;letter-spacing:0.5px}
.exp-right{}
.exp-role{font-size:18px;font-weight:700;color:var(--text);margin-bottom:14px}
.exp-bullets{list-style:none;display:flex;flex-direction:column;gap:9px}
.exp-bullets li{font-size:13px;color:var(--text2);line-height:1.7;padding-left:18px;position:relative}
.exp-bullets li::before{content:'▸';position:absolute;left:0;color:var(--blue);font-size:11px;top:3px}

/* CONNECT */
