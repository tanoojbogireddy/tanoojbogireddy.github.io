*{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#0077B5;
  --blue-dark:#005a8e;
  --blue-light:#e8f4fd;
  --blue-mid:#cce5f5;
  --white:#ffffff;
  --bg:#f7fafd;
  --text:#0f1923;
  --text2:#3a4a58;
  --text3:#6b7e8f;
  --border:#dde8f0;
  --serif:'Playfair Display',serif;
  --sans:'Inter',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--white);color:var(--text);font-family:var(--sans);line-height:1.6}

/* NAV */
nav{position:sticky;top:0;z-index:200;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 64px;display:flex;align-items:center;justify-content:space-between;height:64px}
.nav-logo{font-size:15px;font-weight:700;color:var(--blue);letter-spacing:-0.3px}
.nav-links{display:flex;gap:8px;list-style:none}
.nav-links a{font-size:13px;font-weight:500;color:var(--text2);text-decoration:none;padding:6px 14px;border-radius:6px;transition:all 0.15s}
.nav-links a:hover{background:var(--blue-light);color:var(--blue)}
.nav-cta{background:var(--blue);color:var(--white);font-size:13px;font-weight:600;padding:8px 20px;border-radius:8px;text-decoration:none;transition:background 0.15s}
.nav-cta:hover{background:var(--blue-dark)}

/* HERO */
.hero{padding:96px 64px 80px;background:var(--white);border-bottom:1px solid var(--border)}
.hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 380px;gap:64px;align-items:center}
.hero-available{display:inline-flex;align-items:center;gap:8px;background:var(--blue-light);border:1px solid var(--blue-mid);color:var(--blue);font-size:12px;font-weight:600;padding:6px 14px;border-radius:20px;margin-bottom:28px;letter-spacing:0.3px}
.hero-available::before{content:'';width:7px;height:7px;border-radius:50%;background:#22c55e;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
.hero h1{font-family:var(--serif);font-size:62px;line-height:1.05;letter-spacing:-1px;color:var(--text);margin-bottom:16px}
.hero h1 span{color:var(--blue)}
.hero-role{font-size:15px;color:var(--text3);font-weight:500;margin-bottom:20px;line-height:1.5}
.hero-role b{color:var(--blue);font-weight:600}
.hero-desc{font-size:15px;color:var(--text2);line-height:1.85;margin-bottom:36px;max-width:560px}
.hero-desc strong{color:var(--text);font-weight:600}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-blue{background:var(--blue);color:var(--white);font-size:14px;font-weight:600;padding:12px 28px;border-radius:8px;text-decoration:none;transition:background 0.15s;display:inline-flex;align-items:center;gap:6px}
.btn-blue:hover{background:var(--blue-dark)}
.btn-white{background:var(--white);color:var(--text);font-size:14px;font-weight:500;padding:11px 24px;border-radius:8px;text-decoration:none;border:1.5px solid var(--border);transition:all 0.15s;display:inline-flex;align-items:center;gap:6px}
.btn-white:hover{border-color:var(--blue);color:var(--blue)}

/* HERO CARD */
.hero-card{background:var(--bg);border:1.5px solid var(--border);border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:20px}
.hero-card-top{display:flex;align-items:center;gap:14px}
.avatar{width:56px;height:56px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;color:var(--white);font-size:18px;font-weight:700;font-family:var(--serif);flex-shrink:0}
.avatar-info h3{font-size:15px;font-weight:700;color:var(--text)}
.avatar-info p{font-size:12px;color:var(--text3)}
.hero-card-divider{height:1px;background:var(--border)}
.hero-stats{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.hstat{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:14px 16px}
.hstat-num{font-size:28px;font-weight:700;color:var(--blue);line-height:1;font-family:var(--serif)}
.hstat-label{font-size:11px;color:var(--text3);margin-top:3px;line-height:1.4}
.hero-tags{display:flex;flex-wrap:wrap;gap:6px}
.htag{font-size:11px;font-weight:500;background:var(--blue-light);color:var(--blue);padding:4px 10px;border-radius:20px;border:1px solid var(--blue-mid)}

/* SECTION WRAPPER */
.section{padding:80px 64px;border-bottom:1px solid var(--border)}
.section-inner{max-width:1100px;margin:0 auto}
.section-header{display:flex;align-items:baseline;gap:12px;margin-bottom:48px}
.section-label{font-size:11px;font-weight:700;color:var(--blue);letter-spacing:2px;text-transform:uppercase;background:var(--blue-light);padding:4px 10px;border-radius:4px}
.section-title{font-family:var(--serif);font-size:34px;color:var(--text);letter-spacing:-0.5px}
.section-bg{background:var(--bg)}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.about-text p{font-size:15px;color:var(--text2);line-height:1.85;margin-bottom:16px}
.about-text p:last-child{margin-bottom:0}
.about-text strong{color:var(--text);font-weight:600}
.quote{border-left:3px solid var(--blue);padding:14px 20px;background:var(--blue-light);border-radius:0 8px 8px 0;font-size:15px;font-style:italic;color:var(--text2);margin-top:24px;line-height:1.7}
.edu-cards{display:flex;flex-direction:column;gap:14px}
.edu-card{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:20px 22px;transition:border-color 0.15s}
.edu-card:hover{border-color:var(--blue)}
.edu-card-icon{width:36px;height:36px;background:var(--blue-light);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;margin-bottom:10px}
.edu-card h4{font-size:14px;font-weight:700;color:var(--text);margin-bottom:3px}
.edu-card p{font-size:12px;color:var(--text3);line-height:1.6}
.edu-card .tag{display:inline-block;font-size:10px;font-weight:600;background:var(--blue-light);color:var(--blue);padding:2px 8px;border-radius:4px;margin-top:6px}

/* IMPACT */
.impact-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.impact-card{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:24px;text-align:center;transition:all 0.15s;position:relative;overflow:hidden}
.impact-card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--blue);transform:scaleX(0);transform-origin:left;transition:transform 0.25s}
.impact-card:hover::after{transform:scaleX(1)}
.impact-card:hover{border-color:var(--blue-mid)}
.impact-num{font-family:var(--serif);font-size:48px;font-weight:700;color:var(--blue);line-height:1;margin-bottom:6px}
.impact-num sup{font-size:22px;vertical-align:super}
.impact-label{font-size:13px;color:var(--text2);font-weight:500;line-height:1.4;margin-bottom:4px}
.impact-source{font-size:11px;color:var(--text3)}

/* SKILLS */
.skills-wrap{display:flex;flex-direction:column;gap:28px}
.skill-row{}
.skill-row-title{font-size:12px;font-weight:700;color:var(--text3);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:12px}
.skill-pills{display:flex;flex-wrap:wrap;gap:8px}
.pill{font-size:12px;font-weight:500;background:var(--white);color:var(--text2);border:1.5px solid var(--border);padding:6px 14px;border-radius:20px;transition:all 0.12s;cursor:default}
.pill:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-light)}
.pill.key{background:var(--blue);color:var(--white);border-color:var(--blue)}
.pill.key:hover{background:var(--blue-dark);border-color:var(--blue-dark)}

/* PROJECTS */
.projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.proj-card{background:var(--white);border:1.5px solid var(--border);border-radius:14px;padding:24px;display:flex;flex-direction:column;gap:12px;transition:all 0.2s}
.proj-card:hover{border-color:var(--blue);transform:translateY(-3px)}
.proj-card.featured{border-color:var(--blue-mid);background:var(--bg)}
.proj-type{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--blue)}
