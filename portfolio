.connect-right{display:flex;flex-direction:column;gap:10px;flex-shrink:0}
.connect-btn{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.12);color:var(--white);font-size:13px;font-weight:600;padding:12px 22px;border-radius:8px;text-decoration:none;border:1px solid rgba(255,255,255,0.2);transition:all 0.15s;min-width:220px}
.connect-btn:hover{background:rgba(255,255,255,0.22)}
.connect-btn.primary{background:var(--white);color:var(--blue)}
.connect-btn.primary:hover{background:#f0f8ff}
.connect-icon{font-size:16px}

/* FOOTER */
footer{padding:28px 64px;display:flex;justify-content:space-between;align-items:center;max-width:100%;border-top:1px solid var(--border)}
.footer-left{font-size:13px;color:var(--text3)}
.footer-left span{color:var(--blue);font-weight:600}
.footer-right{font-size:12px;color:var(--text3)}

/* FADE IN */
.fi{opacity:0;transform:translateY(20px);transition:opacity 0.55s ease,transform 0.55s ease}
.fi.show{opacity:1;transform:none}

@media(max-width:960px){
  nav{padding:0 20px}
  .nav-links{display:none}
